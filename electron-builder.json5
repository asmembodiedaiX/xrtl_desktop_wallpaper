{
  appId: 'com.example.wallpaper-app',
  productName: 'Desktop Wallpaper',
  directories: {
    output: 'dist',
    buildResources: 'public',
  },
  files: [
    'build/main/**/*',
    'build/renderer/**/*',
    'node_modules/**/*',
    'package.json',
  ],
  win: {
    target: 'nsis',
    icon: 'public/icon.png',
  },
  mac: {
    target: 'dmg',
    icon: 'public/icon.png',
  },
  linux: {
    target: 'AppImage',
    icon: 'public/icon.png',
  },
}
